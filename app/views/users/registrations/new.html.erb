<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
          <h2 class="fw-light mb-4">Create Account</h2>
          <%= form_for(resource, as: resource_name, url: registration_path(resource_name), local: true) do |f| %>
            <% if resource.errors.any? %>
              <div class="alert alert-danger">
                <% resource.errors.full_messages.each do |msg| %>
                  <p class="mb-0"><%= msg %></p>
                <% end %>
              </div>
            <% end %>
            <div class="mb-3">
              <label class="form-label">Full Name</label>
              <%= f.text_field :name, class: "form-control", required: true %>
            </div>
            <div class="mb-3">
              <label class="form-label">Email</label>
              <%= f.email_field :email, class: "form-control", required: true %>
            </div>
            <div class="mb-3">
              <label class="form-label">Phone</label>
              <%= f.text_field :phone, class: "form-control" %>
            </div>
            <div class="mb-3">
              <label class="form-label">Province</label>
              <%= f.collection_select :province_id, @provinces, :id, :name, { include_blank: "Select Province" }, { class: "form-select" } %>
            </div>
            <div class="mb-3">
              <label class="form-label">Password</label>
              <%= f.password_field :password, class: "form-control", required: true %>
            </div>
            <div class="mb-3">
              <label class="form-label">Confirm Password</label>
              <%= f.password_field :password_confirmation, class: "form-control", required: true %>
            </div>
            <%= f.submit "Sign Up", class: "btn btn-dark w-100 py-2" %>
          <% end %>
          <p class="text-center text-muted small mt-3">
            Already have an account? <%= link_to "Sign In", new_user_session_path %>
          </p>
        </div>
      </div>
    </div>
  </div>
</div>