<div class="container py-5">
  <h1 class="fw-light mb-4">Checkout</h1>

  <div class="row g-4">
    <div class="col-lg-7">
      <%= form_with url: checkout_path, method: :post, local: true, data: { turbo: false } do |f| %>
        <%= hidden_field_tag :stripe_payment_id, "", id: "stripe_payment_id" %>

        <div class="card border-0 shadow-sm mb-4">
          <div class="card-body">
            <h5 class="fw-light mb-3">Your Address</h5>
            <div class="mb-3">
              <label class="form-label small text-muted text-uppercase">Street Address</label>
              <%= text_field_tag :address, current_user.address, class: "form-control", required: true %>
            </div>
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label small text-muted text-uppercase">City</label>
                <%= text_field_tag :city, current_user.city, class: "form-control", required: true %>
              </div>
              <div class="col-md-6">
                <label class="form-label small text-muted text-uppercase">Postal Code</label>
                <%= text_field_tag :postal_code, current_user.postal_code, class: "form-control", required: true %>
              </div>
            </div>
            <div class="mt-3">
              <label class="form-label small text-muted text-uppercase">Province</label>
              <%= select_tag :province_id,
                  options_from_collection_for_select(@provinces, :id, :name, @province&.id),
                  class: "form-select", required: true,
                  onchange: "this.form.submit()",
                  data: { turbo: false } %>
              <% if @province %>
                <small class="text-muted">Tax: <%= @province.tax_summary %></small>
              <% end %>
            </div>
          </div>
        </div>

        <% if @client_secret %>
          <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
              <h5 class="fw-light mb-3">💳 Payment Details</h5>
              <p class="text-muted small mb-3">
                Test card: <strong>4242 4242 4242 4242</strong> — any future date — any CVC
              </p>
              <div id="card-element" class="form-control" style="padding:12px;height:auto;"></div>
              <div id="card-errors" class="text-danger small mt-2"></div>
            </div>
          </div>
        <% end %>

        <div class="card border-0 shadow-sm mb-4">
          <div class="card-body">
            <h5 class="fw-light mb-3">Invoice</h5>
            <% @cart_items.each do |item| %>
              <div class="d-flex justify-content-between mb-2">
                <span><%= item[:room].name %> × <%= item[:quantity] %> night(s)</span>
                <span>$<%= item[:subtotal].round(2) %></span>
              </div>
            <% end %>
            <hr>
            <div class="d-flex justify-content-between text-muted small mb-1">
              <span>Subtotal</span><span>$<%= @subtotal.round(2) %></span>
            </div>
            <% if @province %>
              <% if @province.gst > 0 %>
                <div class="d-flex justify-content-between text-muted small mb-1">
                  <span>GST (<%= (@province.gst * 100).round(1) %>%)</span>
                  <span>$<%= @gst_amount %></span>
                </div>
              <% end %>
              <% if @province.pst > 0 %>
                <div class="d-flex justify-content-between text-muted small mb-1">
                  <span>PST (<%= (@province.pst * 100).round(1) %>%)</span>
                  <span>$<%= @pst_amount %></span>
                </div>
              <% end %>
              <% if @province.hst > 0 %>
                <div class="d-flex justify-content-between text-muted small mb-1">
                  <span>HST (<%= (@province.hst * 100).round(1) %>%)</span>
                  <span>$<%= @hst_amount %></span>
                </div>
              <% end %>
            <% end %>
            <hr>
            <div class="d-flex justify-content-between fw-bold fs-5">
              <span>Total</span>
              <span>$<%= @total %></span>
            </div>
          </div>
        </div>

        <button type="submit" id="submit-btn" class="btn btn-dark w-100 py-3 fs-5 fw-light">
          Confirm Booking & Pay $<%= @total %>
        </button>
      <% end %>
    </div>

    <div class="col-lg-5">
      <div class="card border-0 bg-light">
        <div class="card-body">
          <h5 class="fw-light mb-3">Your Rooms</h5>
          <% @cart_items.each do |item| %>
            <div class="d-flex justify-content-between mb-2 pb-2 border-bottom">
              <div>
                <p class="mb-0 fw-light"><%= item[:room].name %></p>
                <small class="text-muted"><%= item[:quantity] %> night(s) × $<%= item[:price] %></small>
              </div>
              <span>$<%= item[:subtotal].round(2) %></span>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<% if @client_secret %>
  <script src="https://js.stripe.com/v3/"></script>
  <script>
    const stripe = Stripe('<%= @stripe_publishable_key %>');
    const elements = stripe.elements();
    const cardElement = elements.create('card', {
      style: {
        base: {
          fontSize: '16px',
          color: '#1A1614',
          fontFamily: 'DM Sans, sans-serif'
        }
      }
    });
    cardElement.mount('#card-element');

    cardElement.on('change', function(event) {
      const displayError = document.getElementById('card-errors');
      displayError.textContent = event.error ? event.error.message : '';
    });

    const form = document.querySelector('form');
    const submitBtn = document.getElementById('submit-btn');

    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      submitBtn.disabled = true;
      submitBtn.textContent = 'Processing payment...';

      const { paymentIntent, error } = await stripe.confirmCardPayment(
        '<%= @client_secret %>', {
          payment_method: { card: cardElement }
        }
      );

      if (error) {
        document.getElementById('card-errors').textContent = error.message;
        submitBtn.disabled = false;
        submitBtn.textContent = 'Confirm Booking & Pay $<%= @total %>';
      } else {
        document.getElementById('stripe_payment_id').value = paymentIntent.id;
        form.submit();
      }
    });
  </script>
<% end %>