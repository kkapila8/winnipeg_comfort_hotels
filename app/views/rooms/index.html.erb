<div class="container py-5">
  <div class="row mb-4">
    <div class="col">
      <h1 class="fw-light">All Rooms & Suites</h1>
      <p class="text-muted">Browse our available rooms across three Winnipeg locations.</p>
    </div>
  </div>

  <%# Feature 2.6 - Keyword search with category filter %>
  <div class="card mb-4 border-0 bg-light">
    <div class="card-body">
      <%= form_with url: rooms_path, method: :get, local: true, class: "row g-3" do |f| %>
        <div class="col-md-5">
          <label class="form-label small text-muted text-uppercase">Search Rooms</label>
          <%= text_field_tag :keyword, params[:keyword], placeholder: "e.g. king bed, workspace...", class: "form-control" %>
        </div>
        <div class="col-md-3">
          <label class="form-label small text-muted text-uppercase">Category</label>
          <%= select_tag :category_id,
              options_from_collection_for_select(@categories, :id, :name, params[:category_id]),
              include_blank: "All Categories", class: "form-select" %>
        </div>
        <div class="col-md-2">
          <label class="form-label small text-muted text-uppercase">Filter</label>
          <%= select_tag :filter,
              options_for_select([["All Rooms",""],["On Sale","on_sale"],["New","new"],["Recently Updated","recently_updated"]], params[:filter]),
              class: "form-select" %>
        </div>
        <div class="col-md-2 d-flex align-items-end">
          <%= submit_tag "Search", class: "btn btn-dark w-100" %>
        </div>
      <% end %>
    </div>
  </div>

  <%# Feature 2.2 - Category navigation (different from search above) %>
  <div class="d-flex gap-2 flex-wrap mb-4">
    <%= link_to "All Rooms", rooms_path, class: "btn btn-sm #{params[:category_id].blank? && params[:keyword].blank? ? 'btn-dark' : 'btn-outline-dark'}" %>
    <% @categories.each do |cat| %>
      <%= link_to cat.name, category_path(cat), class: "btn btn-sm btn-outline-secondary" %>
    <% end %>
  </div>

  <p class="text-muted small mb-3">Showing <%= @total_count %> room<%= @total_count == 1 ? "" : "s" %></p>

  <% if @rooms.any? %>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
      <% @rooms.each do |room| %>
        <%= render "shared/room_card", room: room %>
      <% end %>
    </div>

    <%# Feature 2.5 - Kaminari pagination %>
    <div class="d-flex justify-content-center mt-5">
      <%= paginate @rooms %>
    </div>
  <% else %>
    <div class="text-center py-5">
      <p class="fs-1">🏨</p>
      <h4 class="fw-light">No rooms found</h4>
      <p class="text-muted">Try a different search or category.</p>
      <%= link_to "View All Rooms", rooms_path, class: "btn btn-dark" %>
    </div>
  <% end %>
</div>