<div class="container py-5">
  <h1 class="fw-light mb-4">My Bookings</h1>

  <% if @orders.any? %>
    <% @orders.each do |order| %>
      <div class="card mb-3 border-0 shadow-sm">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-light mb-0">Order #<%= order.id %></h5>
            <span class="badge <%= order.status == 'paid' ? 'bg-success' : order.status == 'shipped' ? 'bg-info' : 'bg-warning text-dark' %>">
              <%= order.status.capitalize %>
            </span>
          </div>
          <% order.order_items.each do |item| %>
            <div class="d-flex justify-content-between small text-muted">
              <span><%= item.room_name %> × <%= item.quantity %> night(s)</span>
              <span>$<%= item.line_total %></span>
            </div>
          <% end %>
          <hr>
          <div class="d-flex justify-content-between">
            <span class="text-muted small"><%= order.created_at.strftime("%B %d, %Y") %></span>
            <div>
              <strong>Total: $<%= order.total %></strong>
              <%= link_to "View Details", order_path(order), class: "btn btn-sm btn-outline-dark ms-3" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="text-center py-5">
      <p class="fs-1">📋</p>
      <h4 class="fw-light">No bookings yet</h4>
      <%= link_to "Browse Rooms", rooms_path, class: "btn btn-dark" %>
    </div>
  <% end %>
</div>