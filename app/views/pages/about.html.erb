<div class="container py-5">
  <%= render "shared/breadcrumbs", breadcrumbs: @breadcrumbs %>
  <% if @page %>
    <h1 class="fw-light mb-4"><%= @page.title %></h1>
    <div class="row">
      <div class="col-lg-8">
        <%= simple_format @page.content %>
      </div>
    </div>
  <% end %>
</div>