<div class="container py-5">
  <h1 class="fw-light mb-4">Edit Profile</h1>
  <%= form_with model: current_user, url: profile_path, method: :patch, local: true do |f| %>
    <div class="card border-0 shadow-sm" style="max-width:600px;">
      <div class="card-body">
        <div class="mb-3">
          <label class="form-label">Name</label>
          <%= f.text_field :name, class: "form-control" %>
        </div>
        <div class="mb-3">
          <label class="form-label">Phone</label>
          <%= f.text_field :phone, class: "form-control" %>
        </div>
        <div class="mb-3">
          <label class="form-label">Address</label>
          <%= f.text_field :address, class: "form-control" %>
        </div>
        <div class="mb-3">
          <label class="form-label">City</label>
          <%= f.text_field :city, class: "form-control" %>
        </div>
        <div class="mb-3">
          <label class="form-label">Postal Code</label>
          <%= f.text_field :postal_code, class: "form-control" %>
        </div>
        <div class="mb-3">
          <label class="form-label">Province</label>
          <%= f.collection_select :province_id, @provinces, :id, :name, { include_blank: "Select Province" }, { class: "form-select" } %>
        </div>
        <%= f.submit "Save Changes", class: "btn btn-dark" %>
        <%= link_to "Cancel", profile_path, class: "btn btn-outline-secondary ms-2" %>
      </div>
    </div>
  <% end %>
</div>